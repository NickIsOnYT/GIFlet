<Window x:Class="GIFlet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIFlet"
        mc:Ignorable="d"
        Title="GIFlet" Height="800" Width="1250" WindowStartupLocation="CenterScreen">
    <Grid Background="#1E1E1E">
        <TabControl>
            <!-- Create GIF from Images -->
            <TabItem Header="Create GIF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add Images" Click="CreateAddImages_Click" Width="120" Margin="0,0,10,0"/>
                        <Button Content="Clear All" Click="CreateClearImages_Click" Width="100" Height="35"/>
                    </StackPanel>
                    
                    <ListBox x:Name="CreateImageList" Grid.Row="1" SelectionMode="Extended" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding}" Width="60" Height="60" Stretch="Uniform" Margin="5"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Frame Delay (ms):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="CreateFrameDelay" Grid.Column="1" Text="100" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Loop:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                        <TextBox x:Name="CreateLoopCount" Grid.Column="3" Text="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="20,0,0,0">
                            <CheckBox x:Name="CreateNoStackFrames" Content="No Stacking" VerticalAlignment="Center"/>
                            <CheckBox x:Name="CreateFirstFrameBg" Content="First Frame as BG" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="3" Content="Create GIF" Click="CreateGif_Click" Height="45" FontSize="14"/>
                </Grid>
            </TabItem>

            <!-- Split GIF -->
            <TabItem Header="Split GIF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="SplitOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="SplitClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <GroupBox Grid.Column="0" Header="Original GIF" Margin="0,0,5,0">
                            <local:AnimatedImage x:Name="SplitOriginalImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <GroupBox Grid.Column="1" Header="Extracted Frames" Margin="5,0,0,0">
                            <ListBox x:Name="SplitFramesList" SelectionMode="Extended">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding}" Width="80" Height="80" Stretch="Uniform"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Extract Frames" Click="SplitExtractFrames_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Combine GIFs -->
            <TabItem Header="Combine GIFs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add GIFs" Click="CombineAddGifs_Click" Width="120" Height="35" Margin="0,0,10,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Move Up" Click="CombineMoveUp_Click" Width="100" Height="35" Margin="0,0,5,0"/>
                            <Button Content="Move Down" Click="CombineMoveDown_Click" Width="100" Height="35" Margin="0,0,5,0"/>
                            <Button Content="Remove" Click="CombineRemove_Click" Width="100" Height="35"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <ListBox x:Name="CombineGifList" Grid.Row="1" SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding}" Width="60" Height="60" Stretch="Uniform" Margin="5"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Button Grid.Row="2" Content="Combine GIFs" Click="CombineGifs_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Reverse GIF -->
            <TabItem Header="Reverse GIF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="ReverseOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="ReverseClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <GroupBox Grid.Row="1" Header="Preview">
                        <local:AnimatedImage x:Name="ReversePreviewImage" Stretch="Uniform"/>
                    </GroupBox>
                    
                    <Button Grid.Row="2" Content="Reverse GIF" Click="ReverseGif_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Speed GIF -->
            <TabItem Header="Speed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="SpeedOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="SpeedClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="SpeedPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Speed Multiplier:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="SpeedMultiplier" SelectedIndex="1" Width="150">
                                <ComboBoxItem Content="0.25x (4x slower)"/>
                                <ComboBoxItem Content="0.5x (2x slower)"/>
                                <ComboBoxItem Content="1x (normal)"/>
                                <ComboBoxItem Content="2x (2x faster)"/>
                                <ComboBoxItem Content="3x (3x faster)"/>
                                <ComboBoxItem Content="4x (4x faster)"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Apply Speed Change" Click="SpeedApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Optimize GIF -->
            <TabItem Header="Optimize">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="OptimizeOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="OptimizeClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="OptimizePreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Optimization Level:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="OptimizeLevel" SelectedIndex="1" Width="200">
                                    <ComboBoxItem Content="Low (better quality)"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High (smaller file)"/>
                                    <ComboBoxItem Content="Maximum"/>
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="OptimizeRemoveDups" Content="Remove duplicate frames" IsChecked="True"/>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Optimize GIF" Click="OptimizeGif_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Crop GIF -->
            <TabItem Header="Crop">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="CropOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="CropClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="CropPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Width:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CropWidth" Grid.Column="1" Text="0"/>
                            <TextBlock Grid.Column="2" Text="Height:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="CropHeight" Grid.Column="3" Text="0"/>
                        </Grid>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Crop GIF" Click="CropGif_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Resize GIF -->
            <TabItem Header="Resize">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="ResizeOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="ResizeClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="ResizePreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Width:" VerticalAlignment="Center"/>
                            <TextBox x:Name="ResizeWidth" Grid.Column="1" Text="200"/>
                            <TextBlock Grid.Column="2" Text="Height:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="ResizeHeight" Grid.Column="3" Text="200"/>
                        </Grid>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Resize GIF" Click="ResizeGif_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Rotate GIF -->
            <TabItem Header="Rotate/Flip">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="RotateOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="RotateClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="RotatePreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Rotation:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="RotateAngle" SelectedIndex="0" Width="150">
                                <ComboBoxItem Content="0°"/>
                                <ComboBoxItem Content="90°"/>
                                <ComboBoxItem Content="180°"/>
                                <ComboBoxItem Content="270°"/>
                            </ComboBox>
                            <TextBlock Text="Flip:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                            <ComboBox x:Name="FlipDirection" SelectedIndex="0" Width="150">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Horizontal"/>
                                <ComboBoxItem Content="Vertical"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Apply Rotation/Flip" Click="RotateApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Effects -->
            <TabItem Header="Effects">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="EffectsOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="EffectsClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="EffectsPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Effect:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="EffectType" SelectedIndex="0" Width="200">
                                    <ComboBoxItem Content="Blur"/>
                                    <ComboBoxItem Content="Sharpen"/>
                                    <ComboBoxItem Content="Gaussian Blur"/>
                                    <ComboBoxItem Content="Invert"/>
                                    <ComboBoxItem Content="Grayscale"/>
                                    <ComboBoxItem Content="Sepia"/>
                                </ComboBox>
                                <TextBlock Text="Intensity:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                <Slider x:Name="EffectIntensity" Minimum="0" Maximum="100" Value="50" Width="150"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Apply Effect" Click="EffectsApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Color Adjustment -->
            <TabItem Header="Colors">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="ColorOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="ColorClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="ColorPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Brightness:" VerticalAlignment="Center"/>
                                <Slider x:Name="ColorBrightness" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="ColorSlider_ValueChanged"/>
                                <TextBlock x:Name="ColorBrightnessVal" Grid.Column="2" Text="0" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Contrast:" VerticalAlignment="Center"/>
                                <Slider x:Name="ColorContrast" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="ColorSlider_ValueChanged"/>
                                <TextBlock x:Name="ColorContrastVal" Grid.Column="2" Text="0" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saturation:" VerticalAlignment="Center"/>
                                <Slider x:Name="ColorSaturation" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="ColorSlider_ValueChanged"/>
                                <TextBlock x:Name="ColorSaturationVal" Grid.Column="2" Text="0" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Apply Color Changes" Click="ColorApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Transparency -->
            <TabItem Header="Transparency">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="TransparencyOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="TransparencyClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="TransparencyPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Transparency:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Slider x:Name="TransparencyAmount" Minimum="0" Maximum="100" Value="0" Width="200" ValueChanged="TransparencySlider_ValueChanged"/>
                                <TextBlock x:Name="TransparencyAmountVal" Text="0%" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="TransparencyColorKey" Content="Make color transparent (select from preview)" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Apply Transparency" Click="TransparencyApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Add Border -->
            <TabItem Header="Add Border">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="BorderOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="BorderClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Preview">
                            <local:AnimatedImage x:Name="BorderPreviewImage" Stretch="Uniform"/>
                        </GroupBox>
                        
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Width:" VerticalAlignment="Center"/>
                                <TextBox x:Name="BorderWidth" Grid.Column="1" Text="10"/>
                                <TextBlock Grid.Column="2" Text="Color:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <ComboBox x:Name="BorderColor" Grid.Column="3" SelectedIndex="0">
                                    <ComboBoxItem Content="Black"/>
                                    <ComboBoxItem Content="White"/>
                                    <ComboBoxItem Content="Red"/>
                                    <ComboBoxItem Content="Blue"/>
                                    <ComboBoxItem Content="Green"/>
                                </ComboBox>
                                <TextBlock Grid.Column="4" Text="Corner Radius:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <TextBox x:Name="BorderRadius" Grid.Column="5" Text="0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    
                    <Button Grid.Row="2" Content="Add Border" Click="BorderApply_Click" Height="45" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- GIF Debug -->
            <TabItem Header="GIF Debug">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="DebugOpenGif_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="DebugClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="DebugOutput" Text="" FontFamily="Consolas" FontSize="12" Foreground="White"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Video to GIF -->
            <TabItem Header="Video to GIF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open Video" Click="VideoToGifOpen_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="VideoToGifClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <GroupBox Grid.Row="1" Header="Preview">
                        <MediaElement x:Name="VideoPreview" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform"/>
                    </GroupBox>
                    
                    <Grid Grid.Row="2" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start Time (sec):" VerticalAlignment="Center"/>
                        <TextBox x:Name="VideoStartTime" Grid.Column="1" Text="0"/>
                        <TextBlock Grid.Column="2" Text="Duration (sec):" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="VideoDuration" Grid.Column="3" Text="10"/>
                        <TextBlock Grid.Column="4" Text="FPS:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="VideoFps" Grid.Column="5" Text="10"/>
                        <TextBlock Grid.Column="6" Text="Width:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="VideoWidth" Grid.Column="7" Text="480"/>
                    </Grid>
                    
                    <Button Grid.Row="3" Content="Convert to GIF" Click="VideoToGifConvert_Click" Height="45" FontSize="14"/>
                </Grid>
            </TabItem>

            <!-- GIF to Video -->
            <TabItem Header="GIF to Video">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="GifToVideoOpen_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="GifToVideoClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <GroupBox Grid.Row="1" Header="Preview">
                        <local:AnimatedImage x:Name="GifToVideoPreview" Stretch="Uniform"/>
                    </GroupBox>
                    
                    <Grid Grid.Row="2" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Format:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="GifToVideoFormat" Grid.Column="1" SelectedIndex="0">
                            <ComboBoxItem Content="MP4"/>
                            <ComboBoxItem Content="WebM"/>
                            <ComboBoxItem Content="AVI"/>
                        </ComboBox>
                        <TextBlock Grid.Column="2" Text="Quality:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <ComboBox x:Name="GifToVideoQuality" Grid.Column="3" SelectedIndex="2">
                            <ComboBoxItem Content="High"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="Low"/>
                        </ComboBox>
                    </Grid>
                    
                    <Button Grid.Row="3" Content="Export Video" Click="GifToVideoExport_Click" Height="45" FontSize="14"/>
                </Grid>
            </TabItem>

            <!-- Sprite Sheet to GIF -->
            <TabItem Header="Sprite Sheet to GIF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open Image" Click="SpriteToGifOpen_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="SpriteToGifClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <GroupBox Grid.Row="1" Header="Preview">
                        <Image x:Name="SpriteToGifPreview" Stretch="Uniform"/>
                    </GroupBox>
                    
                    <Grid Grid.Row="2" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Columns:" VerticalAlignment="Center"/>
                        <TextBox x:Name="SpriteColumns" Grid.Column="1" Text="4"/>
                        <TextBlock Grid.Column="2" Text="Rows:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="SpriteRows" Grid.Column="3" Text="4"/>
                        <TextBlock Grid.Column="4" Text="Frame Width:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="SpriteFrameWidth" Grid.Column="5" Text="0"/>
                        <TextBlock Grid.Column="6" Text="Frame Height:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="SpriteFrameHeight" Grid.Column="7" Text="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Create GIF" Click="SpriteToGifCreate_Click" Height="45" FontSize="14" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Preview Animation" Click="SpriteToGifPreviewAnim_Click" Height="45" FontSize="14" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- GIF to Sprite Sheet -->
            <TabItem Header="GIF to Sprite Sheet">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open GIF" Click="GifToSpriteOpen_Click" Width="120" Height="35" Margin="0,0,0,10"/>
                        <Button Content="Clear" Click="GifToSpriteClear_Click" Width="80" Height="35" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <GroupBox Grid.Row="1" Header="Preview">
                        <Image x:Name="GifToSpritePreview" Stretch="Uniform"/>
                    </GroupBox>
                    
                    <Grid Grid.Row="2" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Columns:" VerticalAlignment="Center"/>
                        <TextBox x:Name="GifSpriteColumns" Grid.Column="1" Text="4"/>
                        <TextBlock Grid.Column="2" Text="Padding:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="GifSpritePadding" Grid.Column="3" Text="0"/>
                    </Grid>
                    
                    <Button Grid.Row="3" Content="Export Sprite Sheet" Click="GifToSpriteExport_Click" Height="45" FontSize="14"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
